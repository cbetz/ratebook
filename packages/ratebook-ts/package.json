{
  "name": "@ratebook/engine",
  "version": "0.1.0",
  "description": "Deterministic US electricity tariff rate engine — TypeScript port, sharing JSON test vectors with the Python engine.",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "license": "Apache-2.0",
  "author": "Chris Betz (https://github.com/cbetz)",
  "homepage": "https://github.com/cbetz/ratebook#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbetz/ratebook.git",
    "directory": "packages/ratebook-ts"
  },
  "bugs": {
    "url": "https://github.com/cbetz/ratebook/issues"
  },
  "keywords": ["electricity", "tariffs", "energy", "rate-engine", "ratebook"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:demo": "esbuild src/index.ts --bundle --format=iife --global-name=RatebookEngine --minify --outfile=../../demo/ratebook-engine.js"
  },
  "dependencies": {
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
